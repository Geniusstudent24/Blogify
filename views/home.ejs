<!DOCTYPE html>
<html lang="en">
  <head>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7697286449458254"
     crossorigin="anonymous"></script>
    <%- include('./parsels/head') %>
    <title>Discover & Explore</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Poppins:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css"
      rel="stylesheet"
    />

    <style>
      :root {
        --primary-color: #6a00ff;
        --secondary-color: #a170ff;
        --accent-color: #00d2ff;
        --background-start: #f0f2f5;
        --background-end: #e0e5ec;
        --text-dark: #212529;
        --text-light: #f8f9fa;
        --card-bg: rgba(255, 255, 255, 0.95);
        --card-shadow-light: 0 10px 30px rgba(0, 0, 0, 0.1);
        --card-shadow-heavy: 0 20px 45px rgba(0, 0, 0, 0.25);
        --border-radius-lg: 25px;
        --button-gradient: linear-gradient(
          45deg,
          var(--primary-color),
          var(--secondary-color)
        );
        --button-hover-gradient: linear-gradient(
          45deg,
          var(--secondary-color),
          var(--primary-color)
        );
        --glow-color: rgba(106, 0, 255, 0.6);
      }

      body {
        background: var(--background-start);
        background: linear-gradient(
          135deg,
          var(--background-start) 0%,
          var(--background-end) 100%
        );
        font-family: "Poppins", sans-serif;
        color: var(--text-dark);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
        position: relative;
      }

      .background-shapes div {
        position: absolute;
        background: rgba(var(--accent-color), 0.1);
        border-radius: 50%;
        pointer-events: none;
        filter: blur(50px);
        opacity: 0.7;
        animation: float 20s infinite ease-in-out;
        z-index: -1;
      }
      .background-shapes div:nth-child(1) {
        top: 10%;
        left: 5%;
        width: 150px;
        height: 150px;
        animation-delay: 0s;
      }
      .background-shapes div:nth-child(2) {
        top: 40%;
        right: 10%;
        width: 200px;
        height: 200px;
        background: rgba(var(--primary-color), 0.1);
        animation-delay: 5s;
      }
      .background-shapes div:nth-child(3) {
        bottom: 15%;
        left: 20%;
        width: 100px;
        height: 100px;
        background: rgba(var(--secondary-color), 0.1);
        animation-delay: 10s;
      }
      .background-shapes div:nth-child(4) {
        top: 20%;
        right: 30%;
        width: 180px;
        height: 180px;
        animation-delay: 3s;
      }
      .background-shapes div:nth-child(5) {
        bottom: 5%;
        left: 50%;
        width: 250px;
        height: 250px;
        background: rgba(var(--primary-color), 0.1);
        animation-delay: 8s;
      }

      @keyframes float {
        0% {
          transform: translateY(0px) translateX(0px);
        }
        50% {
          transform: translateY(-20px) translateX(10px);
        }
        100% {
          transform: translateY(0px) translateX(0px);
        }
      }

      .hero-section {
        background: linear-gradient(
          135deg,
          var(--primary-color) 0%,
          var(--secondary-color) 100%
        );
        color: var(--text-light);
        padding: 100px 0;
        margin-bottom: 60px;
        text-align: center;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
        position: relative;
        overflow: hidden;
        clip-path: polygon(0 0, 100% 0, 100% 85%, 0% 100%);
      }
      .hero-section::before {
        content: "";
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(
          circle at top left,
          rgba(255, 255, 255, 0.2),
          transparent 70%
        );
        transform: rotate(45deg);
        z-index: 0;
        animation: pulse-light 10s infinite ease-in-out alternate;
      }
      .hero-section h1 {
        font-family: "Montserrat", sans-serif;
        font-weight: 800;
        font-size: 4.5rem;
        letter-spacing: 2px;
        text-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
        margin-bottom: 20px;
        position: relative;
        z-index: 1;
      }
      .hero-section p {
        font-family: "Poppins", sans-serif;
        font-size: 1.5rem;
        max-width: 800px;
        margin: 0 auto;
        opacity: 0.95;
        position: relative;
        z-index: 1;
      }

      @keyframes pulse-light {
        0% {
          transform: scale(1) rotate(45deg);
          opacity: 1;
        }
        100% {
          transform: scale(1.1) rotate(45deg);
          opacity: 0.8;
        }
      }

      .card {
        transition: transform 0.7s cubic-bezier(0.2, 0.8, 0.2, 1),
          box-shadow 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
        border: none;
        border-radius: var(--border-radius-lg);
        box-shadow: var(--card-shadow-light);
        background: var(--card-bg);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        perspective: 1500px;
        overflow: hidden;
        position: relative;
        transform-style: preserve-3d;
        height: 100%;
        display: flex;
        flex-direction: column;
      }

      .card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border-radius: var(--border-radius-lg);
        border: 1px solid rgba(255, 255, 255, 0.3);
        z-index: 0;
        pointer-events: none;
      }

      .card:hover {
        transform: translateY(-15px) rotateX(3deg) rotateY(3deg) scale(1.02);
        box-shadow: var(--card-shadow-heavy), 0 0 40px var(--glow-color);
        border-color: rgba(255, 255, 255, 0.5);
      }

      .card-img-top {
        border-top-left-radius: var(--border-radius-lg);
        border-top-right-radius: var(--border-radius-lg);
        height: 250px;
        object-fit: cover;
        width: 100%;
        transition: transform 0.6s ease-in-out;
      }

      .card:hover .card-img-top {
        transform: scale(1.1);
      }

      .card-body {
        padding: 30px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        flex-grow: 1;
        position: relative;
        z-index: 1;
      }

      .card-title {
        font-family: "Montserrat", sans-serif;
        font-weight: 700;
        color: var(--text-dark);
        font-size: 1.8rem;
        margin-bottom: 20px;
        line-height: 1.2;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.05);
      }

      .btn-primary {
        background: var(--button-gradient);
        border: none;
        border-radius: 35px;
        padding: 15px 35px;
        font-size: 1.2rem;
        font-weight: 600;
        transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
        position: relative;
        overflow: hidden;
        z-index: 1;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
        color: white;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transform: translateZ(10px);
      }

      .btn-primary::before {
        content: "";
        position: absolute;
        top: 0;
        left: -120%;
        width: 80%;
        height: 100%;
        background: rgba(255, 255, 255, 0.4);
        transform: skewX(-30deg);
        transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
        z-index: -1;
      }

      .btn-primary:hover::before {
        left: 120%;
      }

      .btn-primary:hover {
        box-shadow: 0 15px 25px rgba(0, 0, 0, 0.4), 0 0 30px var(--accent-color);
        transform: translateY(-5px) translateZ(15px);
      }

      .btn-primary:active {
        transform: translateY(0) translateZ(5px);
        box-shadow: 0 5px 10px rgba(0, 0, 0, 0.2);
      }

      .container {
        margin-top: 60px;
        margin-bottom: 60px;
        flex-grow: 1;
      }

      .card-grid-row {
        --bs-gutter-x: 3rem;
        --bs-gutter-y: 3rem;
      }

      .empty-state {
        padding: 80px 20px;
        background: rgba(255, 255, 255, 0.8);
        border-radius: var(--border-radius-lg);
        box-shadow: var(--card-shadow-light);
        margin: 50px auto;
        max-width: 600px;
        font-size: 1.3rem;
        color: var(--text-dark);
        text-align: center;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
      }
      .empty-state p {
        margin-bottom: 0;
        font-weight: 500;
      }

      @media (max-width: 1200px) {
        .hero-section h1 {
          font-size: 3.8rem;
        }
        .hero-section p {
          font-size: 1.4rem;
        }
        .card-grid-row {
          --bs-gutter-x: 2rem;
          --bs-gutter-y: 2rem;
        }
        .card-img-top {
          height: 220px;
        }
        .card-title {
          font-size: 1.6rem;
        }
      }

      @media (max-width: 992px) {
        .hero-section {
          padding: 80px 0;
          clip-path: polygon(0 0, 100% 0, 100% 90%, 0% 100%);
        }
        .hero-section h1 {
          font-size: 3rem;
        }
        .hero-section p {
          font-size: 1.2rem;
        }
        .card-grid-row {
          --bs-gutter-x: 1.5rem;
          --bs-gutter-y: 1.5rem;
        }
        .card {
          width: 90%;
          margin-left: auto;
          margin-right: auto;
        }
        .background-shapes div {
          display: none;
        }
      }

      @media (max-width: 768px) {
        .hero-section {
          padding: 60px 0;
          clip-path: polygon(0 0, 100% 0, 100% 95%, 0% 100%);
        }
        .hero-section h1 {
          font-size: 2.5rem;
          letter-spacing: 1px;
        }
        .hero-section p {
          font-size: 1.1rem;
        }
        .card-body {
          padding: 25px;
        }
        .card-title {
          font-size: 1.4rem;
        }
        .btn-primary {
          padding: 12px 28px;
          font-size: 1.1rem;
        }
        .card-img-top {
          height: 200px;
        }
      }

      @media (max-width: 576px) {
        .hero-section {
          padding: 50px 0;
        }
        .hero-section h1 {
          font-size: 2rem;
        }
        .hero-section p {
          font-size: 1rem;
        }
        .card {
          border-radius: 20px;
        }
        .card-img-top {
          border-top-left-radius: 20px;
          border-top-right-radius: 20px;
          height: 180px;
        }
        .card-body {
          padding: 20px;
        }
        .card-title {
          font-size: 1.2rem;
        }
        .btn-primary {
          padding: 10px 24px;
          font-size: 1rem;
        }
      }

      #page-loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.8);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        transition: opacity 0.5s ease-out, visibility 0.5s ease-out;
      }
      .spinner {
        border: 8px solid #f3f3f3;
        border-top: 8px solid var(--primary-color);
        border-radius: 50%;
        width: 60px;
        height: 60px;
        animation: spin 1s linear infinite;
      }

      @keyframes spin {
        0% {
          transform: rotate(0deg);
        }
        100% {
          transform: rotate(360deg);
        }
      }

      .hidden {
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.5s ease-out, visibility 0.5s ease-out;
      }
    </style>
  </head>
  <body>
    <div id="page-loader">
      <div class="spinner"></div>
    </div>
    <%- include('./parsels/nav') %>

    <div class="background-shapes">
      <div data-rellax-speed="-2"></div>
      <div data-rellax-speed="-1"></div>
      <div data-rellax-speed="-3"></div>
      <div data-rellax-speed="-1.5"></div>
      <div data-rellax-speed="-2.5"></div>
    </div>

    <div class="hero-section">
      <div class="container">
        <div class="hero-section">
          <div class="container">
            <% if (typeof pageTitle !== 'undefined' && pageTitle) { %>
            <h1 data-aos="fade-up"><%= pageTitle %></h1>
            <p data-aos="fade-up" data-aos-delay="200">
              All posts from the <%= pageTitle %> category.
            </p>
            <% } else { %>
            <h1 data-aos="fade-up">Discover Amazing Content</h1>
            <p data-aos="fade-up" data-aos-delay="200">
              Dive into a curated collection of our latest posts and creations.
            </p>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="container text-center">
      <div
        class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 card-grid-row justify-content-center"
      >
        <% if (bgls && bgls.length > 0) { %> <% bgls.forEach(bgl => { %>
        <div
          class="col"
          data-aos="fade-up"
          data-aos-duration="1200"
          data-aos-once="true"
          data-aos-delay="<%= 100 * bgls.indexOf(bgl) %>"
        >
          <div class="card h-100">
            <img
              src="<%= bgl.secureCoverUrl || bgl.coverImage %>"
              class="card-img-top"
              alt="<%= bgl.title %> Cover"
              loading="lazy"
            />
            <div class="card-body">
              <h5 class="card-title">
                <%= bgl.title %>
                <% if (bgl.isPrivate) { %>
                    <span class="badge rounded-pill bg-warning text-dark" style="font-size: 0.65rem; margin-left: 5px;">
                      <i class="fas fa-lock me-1"></i> Special
                    </span>
                <% } %>
              </h5>
              <a href="/blog/<%= bgl._id %>" class="btn btn-primary mt-auto"
                >View Details</a
              >
            </div>
          </div>
        </div>
        <% }) %> <% } else { %>
        <div class="col-12">
          <div class="empty-state" data-aos="fade-in" data-aos-duration="1500">
            <p>
              It looks a little empty here! No content available yet. Please
              check back later or contribute something new!
            </p>
          </div>
        </div>
        <% } %>
      </div>
    </div>

    <%- include('./parsels/script') %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>

    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/rellax@1.12.1/rellax.min.js"></script>
    <script>
      AOS.init({
        offset: 120,
        delay: 0,
        duration: 900,
        easing: "ease-in-out",
        once: true,
        mirror: false,
        anchorPlacement: "top-bottom",
      });

      if (window.innerWidth > 768) {
        var rellax = new Rellax(".rellax", {
          speed: -2,
          center: true,
          wrapper: null,
          round: true,
          vertical: true,
          horizontal: false,
        });
      }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      if (localStorage.getItem("blogAdded") === "true") {
        Swal.fire({
          title: "Blog Added Successfully!",
          icon: "success",
          timer: 2000,
          showConfirmButton: false,
        });
        localStorage.removeItem("blogAdded");
      }

      document.addEventListener("DOMContentLoaded", function () {
        const loader = document.getElementById("page-loader");
        if (loader) {
          loader.classList.add("hidden");
          setTimeout(() => {
            loader.style.display = "none";
          }, 500);
        }
      });
    </script>
  </body>
</html>
