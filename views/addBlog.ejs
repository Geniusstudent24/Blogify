<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./parsels/head') %>
    <title>Create New Blog Post</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Poppins:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2j+E6uJm/x9sH/AnXhvI/zaXnlsg/t/Y+uQ=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css"
    />

    <style>
      :root {
        --primary-color: #6a00ff;
        --secondary-color: #a170ff;
        --accent-color: #00d2ff;
        --text-dark: #212529;
        --text-muted: #6c757d;
        --bg-light: #f0f2f5;
        --bg-card: #ffffff;
        --border-radius-lg: 20px;
        --shadow-sm: 0 4px 12px rgba(0, 0, 0, 0.08);
        --shadow-md: 0 8px 25px rgba(0, 0, 0, 0.15);
        --button-gradient: linear-gradient(
          45deg,
          var(--primary-color),
          var(--secondary-color)
        );
        --button-hover-gradient: linear-gradient(
          45deg,
          var(--secondary-color),
          var(--primary-color)
        );
      }

      body {
        font-family: "Poppins", sans-serif;
        background: var(--bg-light);
        color: var(--text-dark);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
      }

      .container {
        max-width: 800px;
        margin-top: 50px;
        margin-bottom: 50px;
        flex-grow: 1;
      }

      .form-card {
        background: var(--bg-card);
        border-radius: var(--border-radius-lg);
        box-shadow: var(--shadow-md);
        padding: 40px;
        text-align: center;
        position: relative;
        z-index: 1;
        margin-top: 20px;
        margin-bottom: 20px;
        overflow: hidden;
      }

      .form-card h1 {
        font-family: "Montserrat", sans-serif;
        font-weight: 700;
        font-size: 2.8rem;
        color: var(--primary-color);
        margin-bottom: 30px;
        text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.1);
      }

      .form-label {
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 8px;
        display: block;
        text-align: left;
      }

      .form-control {
        border-radius: 12px;
        padding: 15px;
        border: 1px solid rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.05);
        font-size: 1.05rem;
      }

      .form-control:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 0.25rem rgba(106, 0, 255, 0.25),
          inset 0 2px 5px rgba(0, 0, 0, 0.05);
        outline: none;
      }

      textarea.form-control {
        min-height: 180px;
        resize: vertical;
      }

      .custom-file-input-wrapper {
        position: relative;
        overflow: hidden;
        display: inline-block;
        width: 100%;
      }

      .custom-file-input-wrapper input[type="file"] {
        position: absolute;
        left: 0;
        top: 0;
        opacity: 0;
        cursor: pointer;
        width: 100%;
        height: 100%;
        z-index: 2;
      }

      .custom-file-input-display {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--bg-card);
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        padding: 15px 20px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.05);
        flex-wrap: nowrap;
      }

      .custom-file-input-display:hover {
        border-color: var(--secondary-color);
        box-shadow: 0 0 0 0.25rem rgba(106, 0, 255, 0.1),
          inset 0 2px 5px rgba(0, 0, 0, 0.05);
      }

      .custom-file-input-display .file-name {
        color: var(--text-muted);
        flex-grow: 1;
        text-align: left;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
        padding-right: 15px;
        min-width: 0;
      }

      .custom-file-input-display .browse-button {
        background: var(--primary-color);
        color: white;
        padding: 8px 18px;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 500;
        transition: background 0.3s ease;
      }

      .custom-file-input-display:hover .browse-button {
        background: var(--secondary-color);
      }

      .btn-primary {
        background: var(--button-gradient);
        border: none;
        border-radius: 30px;
        padding: 15px 40px;
        font-size: 1.15rem;
        font-weight: 600;
        transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        position: relative;
        overflow: hidden;
        z-index: 1;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        color: white;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 25px;
      }

      .btn-primary::before {
        content: "";
        position: absolute;
        top: 0;
        left: -120%;
        width: 80%;
        height: 100%;
        background: rgba(255, 255, 255, 0.4);
        transform: skewX(-30deg);
        transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
        z-index: -1;
      }

      .btn-primary:hover::before {
        left: 120%;
      }

      .btn-primary:hover {
        box-shadow: 0 15px 25px rgba(0, 0, 0, 0.3), 0 0 30px var(--accent-color);
        transform: translateY(-3px);
      }

      .btn-primary:active {
        transform: translateY(0);
        box-shadow: 0 5px 10px rgba(0, 0, 0, 0.2);
      }

      @media (max-width: 768px) {
        .container {
          margin-top: 30px;
          margin-bottom: 30px;
        }
        .form-card {
          padding: 30px;
        }
        .form-card h1 {
          font-size: 2.2rem;
          margin-bottom: 25px;
        }
        .form-control {
          padding: 12px;
          font-size: 1rem;
        }
        textarea.form-control {
          min-height: 150px;
        }
        .btn-primary {
          padding: 12px 30px;
          font-size: 1rem;
        }
      }

      @media (max-width: 576px) {
        .form-card {
          padding: 20px;
        }
        .form-card h1 {
          font-size: 1.8rem;
          margin-bottom: 20px;
        }
        .form-control {
          padding: 10px;
          font-size: 0.95rem;
        }
        textarea.form-control {
          min-height: 120px;
        }
        .btn-primary {
          padding: 10px 25px;
          font-size: 0.95rem;
        }
      }

      #page-loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.8);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        transition: opacity 0.5s ease-out, visibility 0.5s ease-out;
      }
      .spinner {
        border: 8px solid #f3f3f3;
        border-top: 8px solid var(--primary-color);
        border-radius: 50%;
        width: 60px;
        height: 60px;
        animation: spin 1s linear infinite;
      }

      @keyframes spin {
        0% {
          transform: rotate(0deg);
        }
        100% {
          transform: rotate(360deg);
        }
      }

      .hidden {
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.5s ease-out, visibility 0.5s ease-out;
      }
    </style>
  </head>
  <body>
    <div id="page-loader">
      <div class="spinner"></div>
    </div>
    <%- include('./parsels/nav') %>

    <div
      class="container d-flex flex-column align-items-center justify-content-center"
    >
      <div class="form-card" data-aos="fade-up" data-aos-duration="1000">
        <h1>Create New Blog Post</h1>
        <form
          id="addBlogForm"
          action="/blog"
          method="post"
          enctype="multipart/form-data"
        >
          <div class="mb-4" data-aos="fade-up" data-aos-delay="100">
            <label for="coverImage" class="form-label">Cover Image</label>
            <div class="custom-file-input-wrapper">
              <input
                type="file"
                id="coverImage"
                name="coverImage"
                accept="image/*"
              />
              <div class="custom-file-input-display">
                <span class="file-name" id="fileNameDisplay"
                  >No file chosen</span
                >
                <span class="browse-button"
                  ><i class="fas fa-upload me-2"></i>Browse</span
                >
              </div>
            </div>
          </div>

          <div class="mb-4" data-aos="fade-up" data-aos-delay="200">
            <label for="title" class="form-label">Blog Title</label>
            <input
              type="text"
              class="form-control"
              id="title"
              name="title"
              placeholder="Enter blog title"
            />
          </div>

          <div class="mb-4" data-aos="fade-up" data-aos-delay="300">
            <label for="category" class="form-label">Select Category</label>
            <select class="form-select" id="category" name="category" required>
              <option value="General">General</option>
              <option value="Assignment">Assignment</option>
              <option value="Notice">Notice</option>
              <option value="Study Material">Study Material</option>
            </select>
          </div>

          <div class="mb-4" data-aos="fade-up" data-aos-delay="400">
            <label for="body" class="form-label">Blog Content</label>
            <textarea
              class="form-control"
              id="body"
              name="body"
              rows="10"
              placeholder="Write your blog content here..."
            ></textarea>
          </div>

          <div data-aos="fade-up" data-aos-delay="500">
            <button type="submit" class="btn btn-primary w-100">
              Publish Blog
            </button>
          </div>
        </form>
      </div>
    </div>

    <%- include('./parsels/script') %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script
      src="https://cdn.tiny.cloud/1/2hg2ew1riep5p44bjfm7kmk4qzo0ffqj9gepk8pt9znufbfe/tinymce/7/tinymce.min.js"
      referrerpolicy="origin"
    ></script>
    <script src="/socket.io/socket.io.js"></script>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        // --- Initialize TinyMCE Editor ---
        tinymce.init({
          selector: "textarea#body",
          plugins: "image link lists media table code help wordcount",
          toolbar:
            "undo redo | blocks | bold italic | alignleft aligncenter | bullist numlist | link image media",
          height: 500,
          menubar: false,
          file_picker_types: "file image media",
          file_picker_callback: (callback, value, meta) => {
            const input = document.createElement("input");
            input.setAttribute("type", "file");
            input.setAttribute("accept", "application/pdf,image/*");
            input.addEventListener("change", (e) => {
              const file = e.target.files[0];
              const formData = new FormData();
              formData.append("file", file, file.name);
              fetch("/blog/upload", {
                method: "POST",
                body: formData,
              })
                .then((res) => res.json())
                .then((data) => {
                  callback(data.location, { title: file.name });
                })
                .catch((err) => {
                  console.error("Upload Error:", err);
                  alert("File could not be uploaded.");
                });
            });
            input.click();
          },
        });

        // --- Initialize AOS Animations ---
        AOS.init({
          offset: 100,
          delay: 0,
          duration: 800,
          easing: "ease-in-out",
          once: true,
          mirror: false,
          anchorPlacement: "top-bottom",
        });

        // --- Handle the Page Loader ---
        const loader = document.getElementById("page-loader");
        if (loader) {
          loader.classList.add("hidden");
          setTimeout(() => {
            loader.style.display = "none";
          }, 500);
        }

        // --- Handle Form Submission ---
        const socket = io();
        const form = document.getElementById("addBlogForm");
        if (form) {
          form.addEventListener("submit", async (e) => {
            e.preventDefault();

            tinymce.triggerSave(); // This is the important fix

            const formData = new FormData(form);
            try {
              const res = await fetch("/blog", {
                method: "POST",
                body: formData,
              });
              const data = await res.json();
              if (!res.ok || !data.success) {
                throw new Error(data.message || "Blog not added");
              }
              socket.emit("new-blog", data.blog);
              localStorage.setItem("blogAdded", "true");
              window.location.href = "/";
            } catch (err) {
              Swal.fire({
                title: "Error!",
                text: err.message || "Something went wrong!",
                icon: "error",
              });
            }
          });
        }

        // --- Handle Custom File Input Display ---
        const coverImageInput = document.getElementById("coverImage");
        const fileNameDisplay = document.getElementById("fileNameDisplay");
        if (coverImageInput && fileNameDisplay) {
          coverImageInput.addEventListener("change", function () {
            if (this.files && this.files.length > 0) {
              fileNameDisplay.textContent = this.files[0].name;
              fileNameDisplay.style.color = "var(--text-dark)";
            } else {
              fileNameDisplay.textContent = "No file chosen";
              fileNameDisplay.style.color = "var(--text-muted)";
            }
          });
        }
      });
    </script>
  </body>
</html>
