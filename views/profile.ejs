<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= locals.user.firstName %>'s Profile - Blog</title>
    <link rel="icon" type="image/x-icon" href="/images/icon.ico" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2j+E6uJm/x9sH/AnXhvI/zaXnlsg/t/Y+uQ=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Open+Sans:wght@300;400;600&display=swap"
      rel="stylesheet"
    />
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>

    <style>
      :root {
        --primary-color: #6a00ff;
        --secondary-color: #a170ff;
        --accent-color: #00d2ff;
        --text-dark: #212529;
        --text-muted: #6c757d;
        --bg-light: #f8f9fa;
        --bg-card: #ffffff;
        --border-radius-lg: 15px;
        --shadow-sm: 0 4px 12px rgba(0, 0, 0, 0.08);
        --shadow-md: 0 8px 25px rgba(0, 0, 0, 0.15);
        --button-gradient: linear-gradient(
          45deg,
          var(--primary-color),
          var(--secondary-color)
        );
        --button-hover-gradient: linear-gradient(
          45deg,
          var(--secondary-color),
          var(--primary-color)
        );
      }

      body {
        font-family: "Open Sans", sans-serif;
        background: var(--bg-light);
        color: var(--text-dark);
        line-height: 1.7;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: auto;
        position: static;
      }

      .container {
        max-width: 960px;
        z-index: auto;
        position: static;
      }

      .profile-card {
        background: var(--bg-card);
        border-radius: var(--border-radius-lg);
        box-shadow: var(--shadow-md);
        padding: 40px;
        margin-top: 60px;
        margin-bottom: 60px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        backdrop-filter: none;
      }

      .profile-photo {
        width: 160px;
        height: 160px;
        border-radius: 50%;
        object-fit: cover;
        border: 5px solid var(--primary-color);
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.15);
        margin-bottom: 30px;
        transition: transform 0.3s ease-in-out;
      }

      .profile-photo:hover {
        transform: scale(1.05);
      }

      .profile-name {
        font-family: "Playfair Display", serif;
        font-weight: 700;
        font-size: 3rem;
        color: var(--primary-color);
        margin-bottom: 15px;
        line-height: 1.2;
        text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.05);
      }

      .profile-detail {
        font-size: 1.15rem;
        color: var(--text-dark);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
      }

      .profile-detail .icon {
        color: var(--secondary-color);
        font-size: 1.3rem;
      }

      .profile-detail.role {
        font-weight: 600;
        color: var(--primary-color);
        margin-top: 15px;
        font-size: 1.2rem;
      }

      @media (max-width: 992px) {
        .profile-name {
          font-size: 2.5rem;
        }
        .profile-card {
          padding: 30px;
          margin-top: 40px;
          margin-bottom: 40px;
        }
        .profile-photo {
          width: 140px;
          height: 140px;
          margin-bottom: 25px;
        }
      }

      @media (max-width: 768px) {
        .profile-name {
          font-size: 2rem;
        }
        .profile-card {
          padding: 25px;
          margin-top: 30px;
          margin-bottom: 30px;
        }
        .profile-photo {
          width: 120px;
          height: 120px;
          margin-bottom: 20px;
        }
        .profile-detail {
          font-size: 1rem;
        }
        .profile-detail .icon {
          font-size: 1.1rem;
        }
        .profile-detail.role {
          font-size: 1.1rem;
        }
      }

      @media (max-width: 576px) {
        .profile-name {
          font-size: 1.8rem;
        }
        .profile-card {
          padding: 20px;
          margin-top: 20px;
          margin-bottom: 20px;
        }
        .profile-photo {
          width: 100px;
          height: 100px;
          margin-bottom: 15px;
        }
        .profile-detail {
          font-size: 0.9rem;
          flex-direction: column;
          gap: 5px;
        }
        .profile-detail .icon {
          font-size: 1rem;
        }
        .profile-detail.role {
          font-size: 1rem;
        }
      }

      #page-loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.9);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        transition: opacity 0.5s ease-out;
        opacity: 1;
      }

      #page-loader.hidden {
        opacity: 0;
        pointer-events: none;
      }

      .spinner {
        border: 8px solid #f3f3f3;
        border-top: 8px solid var(--primary-color);
        border-radius: 50%;
        width: 60px;
        height: 60px;
        animation: spin 1s linear infinite;
      }

      @keyframes spin {
        0% {
          transform: rotate(0deg);
        }
        100% {
          transform: rotate(360deg);
        }
      }
    </style>
  </head>
  <body>
    <div id="page-loader">
      <div class="spinner"></div>
    </div>

    <%- include('./parsels/nav') %>

    <main class="flex-grow-1 d-flex justify-content-center align-items-center">
      <div class="container">
        <div class="profile-card" data-aos="fade-up" data-aos-duration="1000">
          <img
            src="/<%= locals.user.photo %>"
            class="profile-photo"
            alt="<%= locals.user.firstName %> Profile Photo"
          />
          <h1 class="profile-name">
            <%= locals.user.firstName %> <%= locals.user.lastName %>
          </h1>
          <p class="profile-detail">
            <i class="fas fa-envelope icon"></i>
            <%= locals.user.email %>
          </p>
          <p class="profile-detail role">
            <i class="fas fa-user-tag icon"></i>
            <%= locals.user.role %>
          </p>
        </div>
      </div>
    </main>

    <%- include('./parsels/script') %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script>
      AOS.init({
        offset: 100,
        delay: 0,
        duration: 800,
        easing: "ease-in-out",
        once: true,
        mirror: false,
        anchorPlacement: "top-bottom",
      });

      window.addEventListener("load", function () {
        const loader = document.getElementById("page-loader");
        if (loader) {
          loader.classList.add("hidden");
          setTimeout(() => {
            loader.style.display = "none";
          }, 500);
        }
      });
    </script>
  </body>
</html>
