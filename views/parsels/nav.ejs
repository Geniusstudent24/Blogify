                <% } else { %>
                <i class="fas fa-user-circle me-2"></i>
                <% } %> <%= user.firstName %>
              </a>
              <ul class="dropdown-menu" aria-labelledby="navbarUserDropdown">
                <li><a class="dropdown-item" href="/user/profile">Profile</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" id="logoutLink" href="/user/logout">Logout</a></li>
              </ul>
            </li>
        <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/user/signup">Create Account</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/user/signin">Sign In</a>
            </li>
        <% } %>
      </ul>

      <form class="d-flex search-form" role="search">
        <input class="form-control me-2 search-input" type="search" placeholder="Search blogs..." />
        <button class="btn btn-search" type="submit">
          <i class="fas fa-search"></i>
        </button>
      </form>
